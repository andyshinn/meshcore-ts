{
  "name": "@andyshinn/meshcore-ts",
  "version": "0.1.0",
  "description": "Application-agnostic MeshCore companion-protocol library (Node, TypeScript)",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./transports": {
      "types": "./dist/transports.d.ts",
      "import": "./dist/transports.js",
      "require": "./dist/transports.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p examples/tsconfig.json",
    "example": "tsx --tsconfig examples/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check",
    "format": "biome format --write .",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:preview": "npm --prefix docs run preview"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@stoprocent/noble": "^1.12.0",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "4.1.8",
    "serialport": "^13.0.0",
    "tsup": "8.5.1",
    "tsx": "^4.19.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
