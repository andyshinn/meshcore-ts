{
  "name": "@andyshinn/meshcore-ts",
  "version": "0.1.2-nightly.0",
  "description": "Application-agnostic MeshCore companion-protocol library (Node, TypeScript)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andyshinn/meshcore-ts.git"
  },
  "homepage": "https://andyshinn.as/meshcore-ts/",
  "bugs": "https://github.com/andyshinn/meshcore-ts/issues",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit && pnpm typecheck:examples",
    "typecheck:examples": "tsc -p examples/tsconfig.json",
    "example": "tsx --tsconfig examples/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check",
    "format": "biome format --write .",
    "docs:dev": "pnpm --filter meshcore-ts-docs run dev",
    "docs:build": "pnpm --filter meshcore-ts-docs run build",
    "docs:preview": "pnpm --filter meshcore-ts-docs run preview"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@stoprocent/noble": "^1.12.0",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "4.1.8",
    "serialport": "^13.0.0",
    "tsup": "8.5.1",
    "tsx": "^4.19.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
